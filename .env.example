# Local dev: copy to `.env.local` at repo root (gitignored) and run `npm run dev`.
# Docker / Unraid: copy to `.env` next to docker-compose.yml. Never commit secrets.
# Host port for the web UI (nginx)
WEB_PORT=8080

# PostgreSQL (postgres service)
POSTGRES_USER=parcel
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=parcel_scrubber

# Docker Compose: host must be "postgres". Local dev: use localhost (see compose postgres port if exposed).
DATABASE_URL=postgresql://parcel:change-me-to-a-long-random-string@localhost:5432/parcel_scrubber

# Google OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Console redirect URI exactly (via nginx on WEB_PORT)
# Dev (ng proxy): http://localhost:4200/api/auth/google/callback
# Docker: http://<lan-ip>:8080/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4200/api/auth/google/callback

# Signs session JWT cookies (min 32 random characters)
JWT_SECRET=change-me-to-another-long-random-string

# Set true only when serving over HTTPS (e.g. reverse proxy)
COOKIE_SECURE=false

NODE_ENV=development
