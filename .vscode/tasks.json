{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "npm",
      "script": "dev",
      "path": "${workspaceFolder}",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "npm: start:web",
      "type": "npm",
      "script": "start:web",
      "path": "${workspaceFolder}",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Changes detected",
          "endsPattern": "bundle generation (complete|failed)"
        }
      }
    }
  ]
}
